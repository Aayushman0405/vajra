# GCP Configuration
GCP_PROJECT_ID=vajra-prod
GCP_ZONE=asia-south1-a
GCP_INSTANCE_NAME=vajra-gpu-01
GCP_SERVICE_ACCOUNT=vajra-gpu-sa@vajra-prod.iam.gserviceaccount.com
GCP_CREDENTIALS_JSON= # base64 encoded service account key

# GPU External IP (get from terraform output)
GPU_EXTERNAL_IP=35.200.123.456

# Qdrant
QDRANT_HOST=qdrant.vajra-system.svc.cluster.local
QDRANT_PORT=6333
QDRANT_COLLECTION=vajra-cache

# Model Configuration
CPU_MODEL=phi-3-mini-4k-instruct
CPU_MODEL_ENDPOINT=http://vajra-cpu-model.vajra-system.svc.cluster.local:8000/v1/chat/completions
GPU_MODEL=meta-llama/Llama-3-8b-instruct
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Cache TTLs (seconds)
CACHE_TTL_CODE=3600
CACHE_TTL_FACTUAL=86400
CACHE_TTL_CREATIVE=300
CACHE_SIMILARITY_THRESHOLD=0.92

# GPU Auto-shutdown
IDLE_THRESHOLD=0.1
IDLE_CHECK_INTERVAL=60
DAILY_BUDGET=5.00

# API Keys
VAJRA_API_KEY= # Set in Kubernetes secret

